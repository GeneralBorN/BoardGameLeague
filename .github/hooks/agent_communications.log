woLetterISOLanguageName\n                    })\n                </div>\n                <div class=\"col-md-6\">\n                    @await Html.PartialAsync(\"_DateTimePicker\", new BoardGameLeague.Models.DateTimePickerModel\n                    {\n                        Name = \"EndDate\",\n                        InputId = \"EndDate\",\n                        Label = \"End date\",\n                        Value = Model.EndDate,\n                        Placeholder = \"dd.MM.yyyy HH:mm\",\n                        Culture = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName\n                    })\n                </div>\n                <div class=\"col-md-4\">\n                    <div class=\"form-check mt-4\">\n                        <input asp-for=\"IsOpen\" class=\"form-check-input\" />\n                        <label asp-for=\"IsOpen\" class=\"form-check-label\"></label>\n                    </div>\n                </div>\n            </div>\n            <div class=\"mt-4\">\n                <button type=\"submit\" class=\"btn btn-primary\">Save changes</button>\n                <a asp-action=\"Index\" class=\"btn btn-outline-secondary\">Cancel</a>\n            </div>\n        </form>\n    </div>\n</div>\n"},{"filePath":"d:\\Fax\\ASP_NET\\BoardGameLeague\\Views\\Tournaments\\Delete.cshtml","oldString":"","newString":"@model BoardGameLeague.Models.Tournament\n\n@{\n    ViewData[\"Title\"] = \"Delete Tournament\";\n}\n\n<div class=\"section-shell py-4\">\n    <div class=\"section-header\">\n        <span class=\"eyebrow\">Tournaments</span>\n        <h1>Delete tournament</h1>\n        <p class=\"section-description\">Confirm removal of this tournament from the league schedule.</p>\n    </div>\n\n    <div class=\"card p-4\">\n        <dl class=\"row\">\n            <dt class=\"col-sm-3\">Name</dt><dd class=\"col-sm-9\">@Model.Name</dd>\n            <dt class=\"col-sm-3\">Venue</dt><dd class=\"col-sm-9\">@Model.Venue.Name</dd>\n       