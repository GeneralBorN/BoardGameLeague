{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -Command \"[Console]::In.ReadToEnd() | Add-Content -Path 'D:\\Fax\\ASP_NET\\BoardGameLeague\\copilot-chat-logs\\copilot-chat.log'\""
          }
        ]
      }
    ],
    "preToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -Command \"[Console]::In.ReadToEnd() | Add-Content -Path 'D:\\Fax\\ASP_NET\\BoardGameLeague\\copilot-chat-logs\\copilot-chat.log'\""
          }
        ]
      }
    ],
    "code-accepted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -Command \"$data = [Console]::In.ReadToEnd(); $data | Add-Content -Path 'D:\\Fax\\ASP_NET\\BoardGameLeague\\copilot-chat-logs\\copilot-chat.log'\""
          }
        ]
      }
    ]
  }
}