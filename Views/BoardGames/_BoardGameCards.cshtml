@model List<BoardGameLeague.Models.BoardGame>

<div class="card-grid card-grid-small">
    @foreach (var game in Model)
    {
        <article class="metric-card compact-card">
            <div class="metric-card-top">
                <span class="tag">@game.Category</span>
                <h2>@game.Name</h2>
            </div>
            <div class="metric-card-body">
                <p>Players: <strong>@game.MinPlayers–@game.MaxPlayers</strong></p>
                <p>Play time: <strong>@(game.AveragePlayTime.TotalMinutes.ToString("F0"))</strong> min</p>
                <p>Complexity: <strong>@(game.Complexity.ToString("F1"))</strong></p>
            </div>
            <div class="metric-card-footer">
                <a class="btn btn-outline-info" asp-action="Details" asp-route-id="@game.Id">Explore</a>
                <a class="btn btn-outline-secondary ms-2" asp-action="Edit" asp-route-id="@game.Id">Edit</a>
                <a class="btn btn-outline-danger ms-2 btn-confirm-delete" data-entity="game" asp-action="Delete" asp-route-id="@game.Id">Delete</a>
            </div>
        </article>
    }
</div>
