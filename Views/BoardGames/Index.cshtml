@model List<BoardGameLeague.Models.BoardGame>

@{
    ViewData["Title"] = "Board Games";
}

<div class="section-shell py-4">
    <div class="section-header">
        <span class="eyebrow">Games</span>
        <h1>Board game library</h1>
        <p class="section-description">A compact overview of all league games with category, player count, and complexity details.</p>
    </div>

        <div class="search-panel d-flex flex-wrap align-items-center gap-2">
            <input type="search" class="form-control js-search-input" data-search-url='@Url.Action("Search")' data-target="#game-search-results" placeholder="Search games..." />
            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
            {
                <a class="btn btn-primary" asp-action="Create">Add game</a>
            }
        </div>

        <div id="game-search-results">
            @Html.Partial("_BoardGameCards", Model)
        </div>
</div>
