@model BoardGameLeague.Models.BoardGame

@{
    ViewData["Title"] = "Add Board Game";
}

<div class="section-shell py-4">
    <div class="section-header">
        <span class="eyebrow">Games</span>
        <h1>Add a board game</h1>
        <p class="section-description">Enter the title, category, player count and complexity of a new league game.</p>
    </div>

    <div class="card p-4">
        <form asp-action="Create" method="post" novalidate>
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Category" class="form-label"></label>
                    <select asp-for="Category" class="form-select" asp-items="ViewBag.Categories"></select>
                    <span asp-validation-for="Category" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="MinPlayers" class="form-label"></label>
                    <input asp-for="MinPlayers" class="form-control" />
                    <span asp-validation-for="MinPlayers" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="MaxPlayers" class="form-label"></label>
                    <input asp-for="MaxPlayers" class="form-control" />
                    <span asp-validation-for="MaxPlayers" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="AveragePlayTimeMinutes" class="form-label">Play time (minutes)</label>
                    <input asp-for="AveragePlayTimeMinutes" class="form-control" />
                    <span asp-validation-for="AveragePlayTimeMinutes" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Complexity" class="form-label"></label>
                    <input asp-for="Complexity" class="form-control" value="@Model.Complexity.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)" />
                    <span asp-validation-for="Complexity" class="text-danger"></span>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Save game</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
