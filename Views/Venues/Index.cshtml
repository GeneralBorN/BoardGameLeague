@model List<BoardGameLeague.Models.Venue>

@{
    ViewData["Title"] = "Venues";
}

<div class="section-shell py-4">
    <div class="section-header">
        <span class="eyebrow">Venues</span>
        <h1>Event locations</h1>
        <p class="section-description">See venues that host tournaments and compare capacity, city and surface type.</p>
    </div>

        <div class="search-panel d-flex flex-wrap align-items-center gap-2">
            <input type="search" class="form-control js-search-input" data-search-url='@Url.Action("Search")' data-target="#venue-search-results" placeholder="Search venues..." />
            <a class="btn btn-primary" asp-action="Create">Add venue</a>
        </div>

        <div id="venue-search-results">
            @Html.Partial("_VenueCards", Model)
        </div>
</div>
