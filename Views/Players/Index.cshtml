@model List<BoardGameLeague.Models.Player>

@{
    ViewData["Title"] = "Players";
}

<div class="section-shell py-4">
    <div class="section-header">
        <span class="eyebrow">Players</span>
        <h1>Player roster</h1>
        <p class="section-description">View every competitor across the league, with rating, role and active squads.</p>
    </div>

        <div class="search-panel d-flex flex-wrap align-items-center gap-2">
            <input type="search" class="form-control js-search-input" data-search-url='@Url.Action("Search")' data-target="#player-search-results" placeholder="Search players..." />
            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
            {
                <a class="btn btn-primary" asp-action="Create">Create player</a>
            }
        </div>

        <div id="player-search-results">
            @Html.Partial("_PlayerCards", Model)
        </div>
</div>
