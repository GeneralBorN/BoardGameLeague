@model List<BoardGameLeague.Models.Match>

@{
    ViewData["Title"] = "Matches";
}

<div class="container py-3">
    <h1 class="mb-3 text-warning">Matches</h1>
    <p>Round-robin and knockout matches scheduled in the league.</p>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Tournament</th>
                <th>Date</th>
                <th>Game</th>
                <th>Team A</th>
                <th>Score</th>
                <th>Team B</th>
                <th>Winner</th>
                <th>Completed</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in Model)
            {
                <tr>
                    <td>@m.Tournament.Name</td>
                    <td>@m.StartTime:g</td>
                    <td>@m.Game.Name</td>
                    <td>@m.TeamA.Name</td>
                    <td>@m.ScoreA - @m.ScoreB</td>
                    <td>@m.TeamB.Name</td>
                    <td>@(m.IsCompleted ? m.Winner.Name : "TBD")</td>
                    <td>@(m.IsCompleted ? "Yes" : "No")</td>
                </tr>
            }
        </tbody>
    </table>
</div>