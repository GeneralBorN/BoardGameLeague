@model List<BoardGameLeague.Models.BoardGame>

@{
    ViewData["Title"] = "Board Games";
}

<div class="container py-3">
    <h1 class="mb-3 text-info">Board Games</h1>
    <p>Games used in the league.</p>

    <div class="row row-cols-1 row-cols-md-2 g-3">
        @foreach (var game in Model)
        {
            <div class="col">
                <div class="card h-100 border-info">
                    <div class="card-body">
                        <h5 class="card-title">@game.Name</h5>
                        <p class="card-text mb-1"><strong>Category:</strong> @game.Category</p>
                        <p class="card-text mb-1"><strong>Players:</strong> @game.MinPlayers - @game.MaxPlayers</p>
                        <p class="card-text mb-1"><strong>Avg time:</strong> @game.AveragePlayTime.TotalMinutes:F0 min</p>
                        <p class="card-text"><strong>Complexity:</strong> @game.Complexity:F1</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>