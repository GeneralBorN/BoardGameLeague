@model List<BoardGameLeague.Models.Team>

@{
    ViewData["Title"] = "Teams";
}

<div class="container py-3">
    <h1 class="mb-3 text-primary">Teams</h1>
    <p>All registered teams in the league and their stats.</p>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Region</th>
                <th>Founded</th>
                <th>Record</th>
                <th>Win Rate</th>
                <th>Players</th>
                <th>Tournaments</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var team in Model)
            {
                <tr>
                    <td>@team.Name</td>
                    <td>@team.Region</td>
                    <td>@team.FoundedDate.ToString("yyyy-MM-dd")</td>
                    <td>@team.TotalWins-@team.TotalLosses</td>
                    <td>@team.WinRate:P1</td>
                    <td>@team.Players.Count</td>
                    <td>@team.Tournaments.Count</td>
                    <td>@(team.IsActive ? "Active" : "Inactive")</td>
                </tr>
            }
        </tbody>
    </table>
</div>