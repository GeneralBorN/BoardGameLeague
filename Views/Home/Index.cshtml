@model BoardGameLeague.Models.LeagueDashboardViewModel

@{
    ViewData["Title"] = "League Pulse";
}

<section class="hero-shell py-5">
    <div class="hero-panel">
        <div class="hero-copy">
            <span class="eyebrow">League Pulse</span>
            <h1>Board Game League command center</h1>
            <p class="hero-description">A unique, non-standard dashboard that highlights league momentum, upcoming tournaments, and the teams driving the current season.</p>
            <div class="hero-actions">
                <a class="btn btn-primary btn-lg me-2" asp-controller="Teams" asp-action="Index">Teams</a>
                <a class="btn btn-outline-info btn-lg me-2" asp-controller="Tournaments" asp-action="Index">Tournaments</a>
                <a class="btn btn-outline-warning btn-lg" asp-controller="Matches" asp-action="Index">Matches</a>
            </div>
        </div>
        <div class="hero-summary">
            <div class="summary-card summary-card-large">
                <p class="summary-label">Active squads</p>
                <p class="summary-value">@Model.AllTeams.Count</p>
                <p class="summary-detail">Distinct teams competing this season</p>
            </div>
            <div class="summary-grid">
                <div class="summary-card">
                    <p class="summary-label">Tournaments</p>
                    <p class="summary-value">@Model.AllTournaments.Count</p>
                </div>
                <div class="summary-card">
                    <p class="summary-label">Matches</p>
                    <p class="summary-value">@Model.AllMatches.Count</p>
                </div>
                <div class="summary-card">
                    <p class="summary-label">Games</p>
                    <p class="summary-value">@Model.AllBoardGames.Count</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-shell py-4">
    <div class="row gx-4 gy-4">
        <div class="col-lg-4">
            <div class="card detail-panel accent-panel">
                <div class="card-header">Top teams</div>
                <div class="card-body">
                    <ol class="detail-list items-list">
                        @foreach (var team in Model.TopTeamsByAveragePlayerRating)
                        {
                            <li>@team.Name — @team.Players.Average(p => p.Rating).ToString("F0") rating</li>
                        }
                    </ol>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card detail-panel accent-panel">
                <div class="card-header">Hot streaks</div>
                <div class="card-body">
                    <ul class="detail-list items-list">
                        @foreach (var team in Model.HighWinRateTeams)
                        {
                            <li>@team.Name <span class="badge bg-success">@team.WinRate.ToString("P1")</span></li>
                        }
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card detail-panel accent-panel">
                <div class="card-header">Popular match pieces</div>
                <div class="card-body">
                    <ul class="detail-list items-list">
                        @foreach (var game in Model.PopularGameNames)
                        {
                            <li>@game</li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-shell py-4">
    <div class="card detail-panel">
        <div class="card-header">Upcoming tournaments</div>
        <div class="card-body">
            <div class="table-responsive custom-table-wrapper">
                <table class="table custom-table mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Start</th>
                            <th>Venue</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tournament in Model.UpcomingTournaments)
                        {
                            <tr>
                                <td><a asp-controller="Tournaments" asp-action="Details" asp-route-id="@tournament.Id">@tournament.Name</a></td>
                                <td>@tournament.StartDate:yyyy-MM-dd</td>
                                <td>@tournament.Venue.Name</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
