@model List<BoardGameLeague.Models.Tournament>

@{
    ViewData["Title"] = "Tournaments";
}

<div class="container py-3">
    <h1 class="mb-3 text-success">Tournaments</h1>
    <p>All tournaments run by the league.</p>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Start</th>
                <th>End</th>
                <th>Venue</th>
                <th>Teams</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td>@t.Name</td>
                    <td>@t.Description</td>
                    <td>@t.StartDate.ToString("yyyy-MM-dd")</td>
                    <td>@t.EndDate.ToString("yyyy-MM-dd")</td>
                    <td>@t.Venue.Name</td>
                    <td>@t.Teams.Count</td>
                    <td>@(t.IsOpen ? "Open" : "Closed")</td>
                </tr>
            }
        </tbody>
    </table>
</div>