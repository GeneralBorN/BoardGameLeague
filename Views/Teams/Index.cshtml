@model List<BoardGameLeague.Models.Team>

@{
    ViewData["Title"] = "Teams";
}

<div class="section-shell py-4">
    <div class="section-header">
        <span class="eyebrow">Teams</span>
        <h1>League Teams</h1>
        <p class="section-description">Explore the complete team roster, win rates and active lineups for every league team.</p>
    </div>

    <div class="card-grid">
        @foreach (var team in Model)
        {
            <article class="metric-card">
                <div class="metric-card-top">
                    <span class="tag">@team.Region</span>
                    <h2>@team.Name</h2>
                </div>
                <div class="metric-card-body">
                    <p>Founded: <strong>@team.FoundedDate:yyyy-MM-dd</strong></p>
                    <p>Players: <strong>@team.Players.Count</strong></p>
                    <p>Record: <strong>@team.TotalWins-@team.TotalLosses</strong></p>
                    <p>Win Rate: <strong>@team.WinRate:P1</strong></p>
                </div>
                <div class="metric-card-footer">
                    <a class="btn btn-outline-info" asp-action="Details" asp-route-id="@team.Id">View details</a>
                </div>
            </article>
        }
    </div>
</div>
