@model List<BoardGameLeague.Models.Team>

@{
    ViewData["Title"] = "Teams";
}

<div class="section-shell py-4">
    <div class="section-header">
        <span class="eyebrow">Teams</span>
        <h1>League Teams</h1>
        <p class="section-description">Explore the complete team roster, win rates and active lineups for every league team.</p>
    </div>

        <div class="search-panel d-flex flex-wrap align-items-center gap-2">
            <input type="search" class="form-control js-search-input" data-search-url='@Url.Action("Search")' data-target="#team-search-results" placeholder="Search teams..." />
            <a class="btn btn-primary" asp-action="Create">Create team</a>
        </div>

        <div id="team-search-results">
            @Html.Partial("_TeamCards", Model)
        </div>
</div>
