@model BoardGameLeague.Models.Team

@{
    ViewData["Title"] = "Create Team";
}

<div class="section-shell py-4">
    <div class="section-header">
        <span class="eyebrow">Teams</span>
        <h1>Create new team</h1>
        <p class="section-description">Add a competitive team with region, founding date, and current league record.</p>
    </div>

    <div class="card p-4">
        <form asp-action="Create" method="post" novalidate>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Region" class="form-label"></label>
                    <input asp-for="Region" class="form-control" />
                    <span asp-validation-for="Region" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    @await Html.PartialAsync("_DateTimePicker", new BoardGameLeague.Models.DateTimePickerModel
                    {
                        Name = "FoundedDate",
                        InputId = "FoundedDate",
                        Label = "Founded date",
                        Value = Model.FoundedDate,
                        Placeholder = "dd.MM.yyyy HH:mm",
                        Culture = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName
                    })
                </div>
                <div class="col-md-3">
                    <label asp-for="TotalWins" class="form-label"></label>
                    <input asp-for="TotalWins" class="form-control" />
                    <span asp-validation-for="TotalWins" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="TotalLosses" class="form-label"></label>
                    <input asp-for="TotalLosses" class="form-control" />
                    <span asp-validation-for="TotalLosses" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <div class="form-check mt-4">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>
                </div>
                <div class="col-12">
                    <label asp-for="SelectedPlayerIds" class="form-label">Players</label>
                    <select asp-for="SelectedPlayerIds" class="form-select" asp-items="ViewBag.Players" multiple size="5"></select>
                    <span asp-validation-for="SelectedPlayerIds" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Save team</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
