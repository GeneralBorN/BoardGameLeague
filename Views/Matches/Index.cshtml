@model List<BoardGameLeague.Models.Match>

@{
    ViewData["Title"] = "Matches";
}

<div class="section-shell py-4">
    <div class="section-header">
        <span class="eyebrow">Matches</span>
        <h1>League match card</h1>
        <p class="section-description">Track every scheduled match and navigate directly to the complete matchup breakdown.</p>
    </div>

        <div class="search-panel d-flex flex-wrap align-items-center gap-2">
            <input type="search" class="form-control js-search-input" data-search-url='@Url.Action("Search")' data-target="#match-search-results" placeholder="Search matches..." />
            <a class="btn btn-primary" asp-action="Create">Schedule match</a>
        </div>

        <div id="match-search-results">
            @Html.Partial("_MatchCards", Model)
        </div>
</div>
