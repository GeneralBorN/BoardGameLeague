@model BoardGameLeague.Models.Match

@{
    ViewData["Title"] = "Schedule Match";
}

<div class="section-shell py-4">
    <div class="section-header">
        <span class="eyebrow">Matches</span>
        <h1>Schedule a match</h1>
        <p class="section-description">Choose teams, board game and tournament details for the new match.</p>
    </div>

    <div class="card p-4">
        <form asp-action="Create" method="post" novalidate>
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    @await Html.PartialAsync("_AutocompleteDropdown", new BoardGameLeague.Models.AutocompleteDropdownModel
                    {
                        Name = "TeamAId",
                        InputId = "TeamAInput",
                        HiddenInputId = "TeamAIdHidden",
                        DisplayText = ViewBag.TeamA ?? string.Empty,
                        Label = "Team A",
                        Placeholder = "Search team A...",
                        SearchUrl = "/Matches/LookupTeams",
                        SelectedValue = Model.TeamAId != Guid.Empty ? Model.TeamAId : null
                    })
                </div>
                <div class="col-md-6">
                    @await Html.PartialAsync("_AutocompleteDropdown", new BoardGameLeague.Models.AutocompleteDropdownModel
                    {
                        Name = "TeamBId",
                        InputId = "TeamBInput",
                        HiddenInputId = "TeamBIdHidden",
                        DisplayText = ViewBag.TeamB ?? string.Empty,
                        Label = "Team B",
                        Placeholder = "Search team B...",
                        SearchUrl = "/Matches/LookupTeams",
                        SelectedValue = Model.TeamBId != Guid.Empty ? Model.TeamBId : null
                    })
                </div>
                <div class="col-md-6">
                    @await Html.PartialAsync("_AutocompleteDropdown", new BoardGameLeague.Models.AutocompleteDropdownModel
                    {
                        Name = "GameId",
                        InputId = "GameInput",
                        HiddenInputId = "GameIdHidden",
                        DisplayText = ViewBag.Game ?? string.Empty,
                        Label = "Board game",
                        Placeholder = "Search board game...",
                        SearchUrl = "/Matches/LookupGames",
                        SelectedValue = Model.GameId != Guid.Empty ? Model.GameId : null
                    })
                </div>
                <div class="col-md-6">
                    @await Html.PartialAsync("_AutocompleteDropdown", new BoardGameLeague.Models.AutocompleteDropdownModel
                    {
                        Name = "TournamentId",
                        InputId = "TournamentInput",
                        HiddenInputId = "TournamentIdHidden",
                        DisplayText = ViewBag.Tournament ?? string.Empty,
                        Label = "Tournament",
                        Placeholder = "Search tournament...",
                        SearchUrl = "/Matches/LookupTournaments",
                        SelectedValue = Model.TournamentId != Guid.Empty ? Model.TournamentId : null
                    })
                </div>
                <div class="col-md-6">
                    @await Html.PartialAsync("_DateTimePicker", new BoardGameLeague.Models.DateTimePickerModel
                    {
                        Name = "StartTime",
                        InputId = "MatchStartTime",
                        Label = "Start time",
                        Value = Model.StartTime,
                        Placeholder = "dd.MM.yyyy HH:mm",
                        Culture = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName
                    })
                </div>
                <div class="col-md-3">
                    <label asp-for="ScoreA" class="form-label"></label>
                    <input asp-for="ScoreA" class="form-control" />
                    <span asp-validation-for="ScoreA" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="ScoreB" class="form-label"></label>
                    <input asp-for="ScoreB" class="form-control" />
                    <span asp-validation-for="ScoreB" class="text-danger"></span>
                </div>
                <div class="col-md-12">
                    <div class="form-check mt-3">
                        <input asp-for="IsCompleted" class="form-check-input" />
                        <label asp-for="IsCompleted" class="form-check-label"></label>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Schedule match</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
