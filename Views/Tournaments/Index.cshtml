@model List<BoardGameLeague.Models.Tournament>

@{
    ViewData["Title"] = "Tournaments";
}

<div class="section-shell py-4">
    <div class="section-header">
        <span class="eyebrow">Tournaments</span>
        <h1>Competition schedule</h1>
        <p class="section-description">Review every league tournament, venue and team lineup.</p>
    </div>

        <div class="search-panel d-flex flex-wrap align-items-center gap-2">
            <input type="search" class="form-control js-search-input" data-search-url='@Url.Action("Search")' data-target="#tournament-search-results" placeholder="Search tournaments..." />
            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
            {
                <a class="btn btn-primary" asp-action="Create">Create tournament</a>
            }
        </div>

        <div id="tournament-search-results">
            @Html.Partial("_TournamentCards", Model)
        </div>
</div>
