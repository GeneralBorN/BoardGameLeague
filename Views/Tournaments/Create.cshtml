@model BoardGameLeague.Models.Tournament

@{
    ViewData["Title"] = "Create Tournament";
}

<div class="section-shell py-4">
    <div class="section-header">
        <span class="eyebrow">Tournaments</span>
        <h1>Create tournament</h1>
        <p class="section-description">Schedule a new tournament with venue, dates and team status.</p>
    </div>

    <div class="card p-4">
        <form asp-action="Create" method="post" novalidate>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    @await Html.PartialAsync("_AutocompleteDropdown", new BoardGameLeague.Models.AutocompleteDropdownModel
                    {
                        Name = "VenueId",
                        InputId = "VenueInput",
                        HiddenInputId = "VenueIdHidden",
                        DisplayText = ViewBag.Venue ?? string.Empty,
                        Label = "Venue",
                        Placeholder = "Search venue...",
                        SearchUrl = "/tournaments/lookup/venues",
                        SelectedValue = Model.VenueId != Guid.Empty ? Model.VenueId : null
                    })
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    @await Html.PartialAsync("_DateTimePicker", new BoardGameLeague.Models.DateTimePickerModel
                    {
                        Name = "StartDate",
                        InputId = "StartDate",
                        Label = "Start date",
                        Value = Model.StartDate,
                        Placeholder = "dd.MM.yyyy HH:mm",
                        Culture = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName
                    })
                </div>
                <div class="col-md-6">
                    @await Html.PartialAsync("_DateTimePicker", new BoardGameLeague.Models.DateTimePickerModel
                    {
                        Name = "EndDate",
                        InputId = "EndDate",
                        Label = "End date",
                        Value = Model.EndDate,
                        Placeholder = "dd.MM.yyyy HH:mm",
                        Culture = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName
                    })
                </div>
                <div class="col-md-4">
                    <div class="form-check mt-4">
                        <input asp-for="IsOpen" class="form-check-input" />
                        <label asp-for="IsOpen" class="form-check-label"></label>
                    </div>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Save tournament</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
