@model BoardGameLeague.Models.Tournament

@{
    ViewData["Title"] = "Edit Tournament";
}

<div class="section-shell py-4">
    <div class="section-header">
        <span class="eyebrow">Tournaments</span>
        <h1>Edit tournament</h1>
        <p class="section-description">Adjust the tournament schedule, venue selection, and status.</p>
    </div>

    <div class="card p-4">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" autocomplete="off" novalidate>
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })
            <input asp-for="Id" type="hidden" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" autocomplete="off" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    @await Html.PartialAsync("_AutocompleteDropdown", new BoardGameLeague.Models.AutocompleteDropdownModel
                    {
                        Name = "VenueId",
                        InputId = "VenueInput",
                        HiddenInputId = "VenueIdHidden",
                        DisplayText = ViewBag.Venue ?? string.Empty,
                        Label = "Venue",
                        Placeholder = "Search venue...",
                        SearchUrl = "/tournaments/lookup/venues",
                        SelectedValue = Model.VenueId != Guid.Empty ? Model.VenueId : null
                    })
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="4" autocomplete="off"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    @await Html.PartialAsync("_DateTimePicker", new BoardGameLeague.Models.DateTimePickerModel
                    {
                        Name = "StartDate",
                        InputId = "StartDate",
                        Label = "Start date",
                        Value = Model.StartDate,
                        Placeholder = "dd.MM.yyyy HH:mm",
                        Culture = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName
                    })
                </div>
                <div class="col-md-6">
                    @await Html.PartialAsync("_DateTimePicker", new BoardGameLeague.Models.DateTimePickerModel
                    {
                        Name = "EndDate",
                        InputId = "EndDate",
                        Label = "End date",
                        Value = Model.EndDate,
                        Placeholder = "dd.MM.yyyy HH:mm",
                        Culture = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName
                    })
                </div>
                <div class="col-md-4">
                    <div class="form-check mt-4">
                        <input asp-for="IsOpen" class="form-check-input" />
                        <label asp-for="IsOpen" class="form-check-label"></label>
                    </div>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Save changes</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
        <div class="mt-5">
            <h4>Attachments</h4>
            <form id="attachmentForm" enctype="multipart/form-data" class="mb-3">
                <div class="input-group">
                    <input id="attachmentFile" name="file" type="file" class="form-control" />
                    <button type="submit" class="btn btn-secondary">Upload</button>
                </div>
                <div id="attachmentResult" class="form-text text-danger"></div>
            </form>
            <div id="attachmentList"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function loadAttachments() {
            const response = await fetch(`/tournaments/${encodeURIComponent('@Model.Id')}/attachments`);
            if (response.ok) {
                document.getElementById('attachmentList').innerHTML = await response.text();
            }
        }

        async function deleteAttachment(id) {
            if (!confirm('Delete this attachment?')) {
                return;
            }
            const response = await fetch('/tournaments/attachments/' + id, {
                method: 'DELETE'
            });
            if (response.ok) {
                loadAttachments();
            }
        }

        document.getElementById('attachmentForm').addEventListener('submit', async function (event) {
            event.preventDefault();
            const fileInput = document.getElementById('attachmentFile');
            const file = fileInput.files[0];
            if (!file) {
                document.getElementById('attachmentResult').textContent = 'Select a file to upload.';
                return;
            }
            const formData = new FormData();
            formData.append('file', file);
            const response = await fetch(`/tournaments/${encodeURIComponent('@Model.Id')}/attachments`, {
                method: 'POST',
                body: formData
            });
            if (response.ok) {
                fileInput.value = '';
                document.getElementById('attachmentResult').textContent = '';
                loadAttachments();
            } else {
                document.getElementById('attachmentResult').textContent = 'Upload failed.';
            }
        });

        loadAttachments();
    </script>
}
