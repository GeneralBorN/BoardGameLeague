@model BoardGameLeague.Models.Tournament

@{
    ViewData["Title"] = "Delete Tournament";
}

<div class="section-shell py-4">
    <div class="section-header">
        <span class="eyebrow">Tournaments</span>
        <h1>Delete tournament</h1>
        <p class="section-description">Confirm removal of this tournament from the league schedule.</p>
    </div>

    <div class="card p-4">
        <dl class="row">
            <dt class="col-sm-3">Name</dt><dd class="col-sm-9">@Model.Name</dd>
            <dt class="col-sm-3">Venue</dt><dd class="col-sm-9">@Model.Venue.Name</dd>
            <dt class="col-sm-3">Dates</dt><dd class="col-sm-9">@Model.StartDate.ToString("yyyy-MM-dd") – @Model.EndDate.ToString("yyyy-MM-dd")</dd>
            <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@(Model.IsOpen ? "Open" : "Closed")</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
